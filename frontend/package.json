        "@types/luxon": "^3.7.1",
        "@types/node": "^18.18.0",
        "@zamiell/typedoc-plugin-not-exported": "^0.3.0",
        "eslint": "^9.39.2",
        "eslint-plugin-jsdoc": "^62.9.0",
        "globals": "^17.0.0",
        "jasmine-core": "~5.6.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
