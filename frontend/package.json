{
    "name": "house-mix-frontend",
    "version": "0.4.1",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "start-dev": "ng serve --build-target=house-mix:build:development --port 4201\n",
        "build:common": "tsc -p ../common/tsconfig.json",
        "build": "npm run build:common && ng build --configuration production --base-href /house-mix/",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "postinstall": "patch-package"
    },
    "private": true,
    "dependencies": {
        "@angular/cdk": "^21.1.1",
        "@angular/common": "^21.1.1",
